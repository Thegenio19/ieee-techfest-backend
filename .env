# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development        # "development" or "production"

# ─── SQLite ────────────────────────────────────────────────────────────────────
# Path to the SQLite database file. It will be created automatically on first run.
DB_PATH=./data/techfest.db

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Access token secret — used to sign short-lived JWTs (15 minutes).
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=f001e306bd464846ae4bd4c22524370ef1a9508271665516f8ddc825411f4915fd553d11998996e6611212b7a745d595452f6be9521f42abb5556991ea88804d

# Refresh token secret — separate secret so a leaked access secret can't forge refresh tokens.
JWT_REFRESH_SECRET=17d118d454dc8bc217028659d90acec459e2e798f27d100b0162773b26915c25629461164067bdd4cc204f10d70377d7c731e302fb6513f29e081f39e8ffd4d4

# How long access tokens last (ms format or zeit/ms string like "15m", "1h")
JWT_ACCESS_EXPIRES_IN=15m

# How long refresh tokens last
JWT_REFRESH_EXPIRES_IN=7d

# ─── QR Code signing ───────────────────────────────────────────────────────────
# HMAC secret used to sign QR code payloads, so volunteers can verify they are
# not tampered. Different from JWT secrets to limit blast radius if one leaks.
QR_SECRET=48f1ee08810be737acdc57dc74a26a5812be156de598772c1625514203e73b5fc1c521d047f86cb0618f0ad97c631656dc3503f987f13598cddc5f7307c6d99c

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL. Default for WSL: redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# ─── Razorpay ──────────────────────────────────────────────────────────────────
# Get these from your Razorpay dashboard → Settings → API Keys.
# Use TEST keys during development — they won't charge real money.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Razorpay sends payment events (webhooks) to this secret endpoint.
# This is the secret you set in Razorpay dashboard → Webhooks → Secret.
RAZORPAY_WEBHOOK_SECRET=change_me_webhook_secret

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# How many requests per minute per IP the token bucket allows.
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ─── Circuit Breaker ───────────────────────────────────────────────────────────
# How many Razorpay failures in a row before we stop calling them.
CIRCUIT_BREAKER_THRESHOLD=5
# How long (ms) to wait in OPEN state before trying Razorpay again.
CIRCUIT_BREAKER_TIMEOUT_MS=30000

# ─── Event registration ────────────────────────────────────────────────────────
# Maximum number of registrations allowed (capacity of the fest).
MAX_REGISTRATIONS=500

# Ticket price in paise (Indian currency smallest unit). 50000 = ₹500.
# Razorpay always works in paise, not rupees.
TICKET_PRICE_PAISE=50000